{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FullReadAccess",
      "Effect": "Allow",
      "Action": [
        "Describe*",
        "Get*",
        "List*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "FullEC2Access",
      "Effect": "Allow",
      "Action": "ec2:*",
      "Resource": "*"
    },
    {
      "Sid": "DenySecrets",
      "Effect": "Deny",
      "Action": [
        "secretsmanager:*",
        "ssm:GetParameter*",
        "ssm:GetParameters*",
        "ssm:GetParameterHistory*"
      ],
      "Resource": "*"
    }
  ]
}